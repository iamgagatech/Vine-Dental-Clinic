# ============================================
# Vine Dental Clinic - Environment Variables
# ============================================
# Copy this file to .env.local for local development
# All variables below are optional except ADMIN_TOKEN for admin access

# ============================================
# APPLICATION
# ============================================
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME="Vine Dental Clinic"

# ============================================
# ADMINISTRATION (Required for admin access)
# ============================================
ADMIN_TOKEN=vine-dental-2025-secure-token

# ============================================
# PAYSTACK INTEGRATION
# ============================================
# Get your keys from: https://dashboard.paystack.co/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# ============================================
# NOTIFICATIONS (Stubs - Configure for production)
# ============================================
# Email Settings (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@vinedentalclinic.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Vine Dental Clinic <notifications@vinedentalclinic.com>"

# SMS (Africa's Talking / Termii)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=VineDental

# ============================================
# ANALYTICS (Optional)
# ============================================
VITE_GA_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=phc_xxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================================
# CONTENT & FEATURES
# ============================================
# Show "Book Now" CTA (true/false)
VITE_ENABLE_BOOKING=true

# Show WhatsApp button (true/false)
VITE_ENABLE_WHATSAPP=true

# Clinic hours display
VITE_HOURS_MON_SAT="9AM-4PM"
VITE_HOURS_SUN="Closed"

# ===========================================
# SECURITY & API KEYS (Add as needed)
# ===========================================
# SENTRY_DSN=https://your-sentry-dsn
# RESEND_API_KEY=re_xxxxx
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx